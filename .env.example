# Copy this file to `.env` and fill in your own values.
# `.env` is gitignored - never commit real keys.
#
# Shell users: `export $(grep -v '^#' .env | xargs)` or source it from your profile.
# VS Code / Jupyter load `.env` from the workspace root automatically.

# --- LLM backends (set the ones you use) ---
# OpenAI-backed runs (reflect-sweep, --backend openai)
OPENAI_API_KEY=

# Portkey gateway runs (PortkeyLLMPrompter, edge labelling, several notebooks)
PORTKEY_API_KEY=
PORTKEY_VIRTUAL_KEY=

# Anthropic-backed runs (AnthropicLLMPrompter)
ANTHROPIC_API_KEY=

# --- Data and output locations ---
# Root containing sim_data/ and reflect_dataset/real_data/ (see docs/data_and_artifacts.md)
REFLECT_DATA_ROOT=
# Where generated scene graphs, summaries, traces, and sweep outputs are written
REFLECT_OUTPUT_ROOT=
